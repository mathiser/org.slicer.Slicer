<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.slicer.Slicer</id>
  <name>3D Slicer</name>
  <summary>Medical image analysis and visualization platform</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>BSD-2-Clause</project_license>

  <description>
    <p>
      3D Slicer is a free, open-source platform for medical image informatics,
      image processing, and three-dimensional visualization. Built over two
      decades through support from the National Institutes of Health and a
      worldwide developer community, Slicer brings powerful medical image
      analysis tools to physicians, researchers, and the general public.
    </p>
    <p>Features include:</p>
    <ul>
      <li>DICOM, NIfTI, NRRD, and many other medical image format support</li>
      <li>Volume rendering and multi-planar reconstruction</li>
      <li>Segmentation with manual, semi-automatic, and AI-assisted tools</li>
      <li>Image registration</li>
      <li>Extensible via a large ecosystem of community extensions</li>
      <li>Python scripting console</li>
    </ul>
  </description>

  <developer id="org.slicer">
    <name>Slicer Community</name>
  </developer>

  <url type="homepage">https://www.slicer.org/</url>
  <url type="bugtracker">https://github.com/Slicer/Slicer/issues</url>
  <url type="help">https://discourse.slicer.org/</url>

  <launchable type="desktop-id">org.slicer.Slicer.desktop</launchable>

  <provides>
    <binary>slicer</binary>
  </provides>

  <categories>
    <category>Science</category>
    <category>MedicalSoftware</category>
  </categories>

  <keywords>
    <keyword>DICOM</keyword>
    <keyword>MRI</keyword>
    <keyword>CT</keyword>
    <keyword>segmentation</keyword>
    <keyword>medical imaging</keyword>
    <keyword>NIfTI</keyword>
    <keyword>radiology</keyword>
  </keywords>

